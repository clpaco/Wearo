{
  "cli": {
    "version": ">= 3.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal"
    },
    "simulator": {
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_NO_CODESIGN": "1"
      }
    },
    "production": {}
  },
  "submit": {
    "production": {}
  }
}
